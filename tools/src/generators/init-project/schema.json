{
  "$schema": "http://json-schema.org/schema",
  "cli": "nx",
  "id": "init-project",
  "title": "Initialize AI-Driven Development System",
  "description": "Scaffold the complete .agents/ registry, templates, workflows, skills, and prototype app for your project",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name (kebab-case)",
      "x-prompt": "What is your project name?"
    },
    "description": {
      "type": "string",
      "description": "One-line project description",
      "x-prompt": "Describe your project in one sentence:"
    },
    "domain": {
      "type": "string",
      "description": "Business domain",
      "x-prompt": {
        "message": "What is the business domain?",
        "type": "list",
        "items": [
          { "value": "e-commerce", "label": "E-commerce" },
          { "value": "healthcare", "label": "Healthcare" },
          { "value": "education", "label": "Education / LMS" },
          { "value": "fintech", "label": "Fintech / Banking" },
          { "value": "saas", "label": "SaaS Platform" },
          { "value": "media", "label": "Media / Content" },
          { "value": "social", "label": "Social / Community" },
          { "value": "other", "label": "Other" }
        ]
      }
    },
    "architectureStyle": {
      "type": "string",
      "description": "Architecture style",
      "enum": ["monolith", "modular-monolith", "microservices"],
      "x-prompt": {
        "message": "What architecture style?",
        "type": "list",
        "items": [
          { "value": "monolith", "label": "Monolith — single deployable unit" },
          { "value": "modular-monolith", "label": "Modular monolith — separate modules, single deploy" },
          { "value": "microservices", "label": "Microservices — independent services" }
        ]
      }
    },
    "frontendFramework": {
      "type": "string",
      "description": "Frontend framework",
      "enum": ["react", "vue", "svelte", "angular", "none"],
      "x-prompt": {
        "message": "What frontend framework?",
        "type": "list",
        "items": [
          { "value": "react", "label": "React" },
          { "value": "vue", "label": "Vue" },
          { "value": "svelte", "label": "Svelte" },
          { "value": "angular", "label": "Angular" },
          { "value": "none", "label": "None (backend-only)" }
        ]
      }
    },
    "cssFramework": {
      "type": "string",
      "description": "CSS framework",
      "enum": ["tailwind", "css-modules", "styled-components", "none"],
      "default": "tailwind"
    },
    "backendFramework": {
      "type": "string",
      "description": "Backend framework",
      "enum": ["express", "fastify", "nestjs", "koa", "none"],
      "default": "koa"
    },
    "testFramework": {
      "type": "string",
      "description": "Test framework",
      "enum": ["vitest", "jest"],
      "default": "vitest"
    },
    "e2eFramework": {
      "type": "string",
      "description": "E2E test framework",
      "enum": ["playwright", "cypress"],
      "default": "playwright"
    },
    "orm": {
      "type": "string",
      "description": "ORM / database toolkit",
      "enum": ["drizzle", "prisma", "typeorm", "none"],
      "default": "drizzle"
    },
    "hasMessageQueue": {
      "type": "boolean",
      "description": "Does the project use a message queue?",
      "default": false
    }
  },
  "required": ["name", "description", "domain", "architectureStyle", "frontendFramework"]
}
