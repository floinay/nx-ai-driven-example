{
  "$schema": "https://json-schema.org/schema",
  "$id": "AddAgent",
  "title": "Add a new agent to the registry and sync all derived files",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent name (kebab-case)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Agent name (kebab-case)"
    },
    "model": {
      "type": "string",
      "description": "Model to use",
      "enum": ["opus", "sonnet", "haiku"],
      "x-prompt": "Model"
    },
    "tools": {
      "type": "string",
      "description": "Comma-separated list of tools (e.g. Read, Glob, Grep)",
      "x-prompt": "Tools (comma-separated)"
    },
    "description": {
      "type": "string",
      "description": "Agent description",
      "x-prompt": "Description"
    },
    "permissionMode": {
      "type": "string",
      "description": "Permission mode",
      "enum": ["default", "acceptEdits"],
      "default": "default"
    }
  },
  "required": ["name", "model", "tools", "description"]
}
