{
  "$schema": "https://json-schema.org/schema",
  "$id": "UpdateSpec",
  "title": "Update spec frontmatter fields",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string",
      "description": "Spec slug (matches filename without .md)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Spec slug"
    },
    "status": {
      "type": "string",
      "description": "New status",
      "enum": ["stub", "draft", "ready", "in-progress", "done"],
      "x-prompt": "New status"
    },
    "milestone": {
      "type": "string",
      "description": "Milestone assignment (e.g. M3, M4)"
    },
    "size": {
      "type": "string",
      "description": "Size estimate",
      "enum": ["XS", "S", "M", "L", "XL"]
    }
  },
  "required": ["slug"]
}
