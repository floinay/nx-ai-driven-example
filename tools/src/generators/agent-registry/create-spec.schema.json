{
  "$schema": "https://json-schema.org/schema",
  "$id": "CreateSpec",
  "title": "Create a new spec from template",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string",
      "description": "Spec slug (kebab-case, used as filename)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Spec slug (kebab-case)"
    },
    "goal": {
      "type": "string",
      "description": "Spec goal description",
      "x-prompt": "Goal (1-2 sentences)"
    },
    "status": {
      "type": "string",
      "description": "Initial status (stub or draft)",
      "default": "stub",
      "enum": ["stub", "draft"]
    },
    "milestone": {
      "type": "string",
      "description": "Milestone assignment (e.g. M3, M4)"
    }
  },
  "required": ["slug", "goal"]
}
