{
  "$schema": "https://json-schema.org/schema",
  "$id": "RemoveAgent",
  "title": "Remove an agent from the registry and sync all derived files",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent name to remove",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Agent name to remove"
    }
  },
  "required": ["name"]
}
