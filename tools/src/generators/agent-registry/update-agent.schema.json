{
  "$schema": "https://json-schema.org/schema",
  "$id": "UpdateAgent",
  "title": "Update an existing agent",
  "type": "object",
  "properties": {
    "name": {"type": "string", "$default": {"$source": "argv", "index": 0}, "x-prompt": "Agent name"},
    "model": {"type": "string", "enum": ["opus", "sonnet", "haiku"]},
    "tools": {"type": "string"},
    "description": {"type": "string"},
    "permissionMode": {"type": "string", "enum": ["default", "acceptEdits"]}
  },
  "required": ["name"]
}
