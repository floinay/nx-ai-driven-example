{
  "$schema": "https://json-schema.org/schema",
  "$id": "UpdateAgent",
  "title": "Update an existing agent in the registry and sync all derived files",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent name (must already exist in registry)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "Agent name"
    },
    "model": {
      "type": "string",
      "description": "Model to use",
      "enum": ["opus", "sonnet", "haiku"]
    },
    "tools": {
      "type": "string",
      "description": "Comma-separated list of tools"
    },
    "description": {
      "type": "string",
      "description": "Agent description"
    },
    "permissionMode": {
      "type": "string",
      "description": "Permission mode",
      "enum": ["default", "acceptEdits"]
    }
  },
  "required": ["name"]
}
