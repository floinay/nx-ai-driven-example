{
  "generators": {
    "create-spec": {
      "factory": "./src/generators/agent-registry/create-spec",
      "schema": "./src/generators/agent-registry/create-spec.schema.json",
      "description": "Create a new spec from template"
    },
    "update-spec": {
      "factory": "./src/generators/agent-registry/update-spec",
      "schema": "./src/generators/agent-registry/update-spec.schema.json",
      "description": "Update spec frontmatter fields"
    },
    "start-task": {
      "factory": "./src/generators/agent-registry/start-task",
      "schema": "./src/generators/agent-registry/start-task.schema.json",
      "description": "Create branch and worktree for a task"
    },
    "finish-task": {
      "factory": "./src/generators/agent-registry/finish-task",
      "schema": "./src/generators/agent-registry/finish-task.schema.json",
      "description": "Cleanup worktree and mark spec as done"
    },
    "abort-task": {
      "factory": "./src/generators/agent-registry/abort-task",
      "schema": "./src/generators/agent-registry/abort-task.schema.json",
      "description": "Cleanup worktree without merging"
    }
  }
}
