{
  "generators": {
    "init-project": {
      "factory": "./src/generators/init-project/generator",
      "schema": "./src/generators/init-project/schema.json",
      "description": "Initialize AI-driven development system for your project"
    },
    "sync-agents": {
      "factory": "./src/generators/agent-registry/sync-agents",
      "schema": "./src/generators/agent-registry/sync-agents.schema.json",
      "description": "Regenerate .claude/agents/*.md from the agent registry"
    },
    "sync-skills": {
      "factory": "./src/generators/agent-registry/sync-skills",
      "schema": "./src/generators/agent-registry/sync-skills.schema.json",
      "description": "Regenerate .claude/skills/*/SKILL.md from skill sources"
    },
    "sync-settings": {
      "factory": "./src/generators/agent-registry/sync-settings",
      "schema": "./src/generators/agent-registry/sync-settings.schema.json",
      "description": "Regenerate .claude/settings.json from settings.yaml + hooks.yaml"
    },
    "sync-commands": {
      "factory": "./src/generators/agent-registry/sync-commands",
      "schema": "./src/generators/agent-registry/sync-commands.schema.json",
      "description": "Regenerate .claude/skills/<command>/SKILL.md from workflows.yaml"
    },
    "sync-codex": {
      "factory": "./src/generators/agent-registry/sync-codex",
      "schema": "./src/generators/agent-registry/sync-codex.schema.json",
      "description": "Regenerate .codex/ from the agent registry"
    },
    "sync-dashboard": {
      "factory": "./src/generators/agent-registry/sync-dashboard",
      "schema": "./src/generators/agent-registry/sync-dashboard.schema.json",
      "description": "Regenerate .agents/specs/INDEX.md dashboard from spec frontmatter"
    },
    "sync-all": {
      "factory": "./src/generators/agent-registry/sync-all",
      "schema": "./src/generators/agent-registry/sync-all.schema.json",
      "description": "Run all sync generators"
    },
    "add-agent": {
      "factory": "./src/generators/agent-registry/add-agent",
      "schema": "./src/generators/agent-registry/add-agent.schema.json",
      "description": "Add a new agent to the registry and sync all derived files"
    },
    "update-agent": {
      "factory": "./src/generators/agent-registry/update-agent",
      "schema": "./src/generators/agent-registry/update-agent.schema.json",
      "description": "Update an existing agent in the registry and sync all derived files"
    },
    "remove-agent": {
      "factory": "./src/generators/agent-registry/remove-agent",
      "schema": "./src/generators/agent-registry/remove-agent.schema.json",
      "description": "Remove an agent from the registry and sync all derived files"
    },
    "create-spec": {
      "factory": "./src/generators/agent-registry/create-spec",
      "schema": "./src/generators/agent-registry/create-spec.schema.json",
      "description": "Create a new spec from template"
    },
    "update-spec": {
      "factory": "./src/generators/agent-registry/update-spec",
      "schema": "./src/generators/agent-registry/update-spec.schema.json",
      "description": "Update spec frontmatter fields"
    },
    "validate-registry": {
      "factory": "./src/generators/agent-registry/validate-registry",
      "schema": "./src/generators/agent-registry/validate-registry.schema.json",
      "description": "Check that all derived files match the agent registry"
    }
  }
}
